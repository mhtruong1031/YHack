# Supabase: Project Settings → Database → Connection string (URI).
# Use the "Session" or direct (port 5432) URI. Example:
#   postgresql://postgres.[ref]:[PASSWORD]@aws-0-...pooler.supabase.com:6543/postgres
# Password: URL-encode special characters (@ : / # etc.).
# This app accepts postgresql:// or postgres://; runtime uses psycopg async automatically.
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/postgres
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://your-api-audience
GEMINI_API_KEY=
DEVICE_INGEST_SECRET=change-me-long-random
# Comma-separated exact browser origins (no path). Must match the page origin when the SPA
# calls the API on another host (e.g. VITE_API_BASE_URL=https://api.example.com).
# Include both http://localhost:5173 and http://127.0.0.1:5173 if you use either.
# (Typo alias: CORS_ORIGIN is also read.)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional: allow previews without listing each URL (full-match regex on Origin).
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
# Optional: scripts/mock_plinko_drop.py default URL (must match Railway DEVICE_INGEST_SECRET)
# DROP_URL=https://yhack-production.up.railway.app/internal/drops
# Optional; default in code is gemini-2.5-flash (gemini-1.5-flash is retired on the current API).
# GEMINI_MODEL=gemini-2.5-flash
